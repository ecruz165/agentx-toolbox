{
  "name": "@ecruz165/gittyup",
  "version": "0.1.0",
  "description": "Multi-repo orchestration CLI with interactive conflict resolution. Part of the agentx-toolbox monorepo.",
  "type": "module",
  "bin": {
    "gittyup": "./bin/gittyup.mjs"
  },
  "main": "./dist/cli.js",
  "files": [
    "bin",
    "dist",
    "branding.yaml",
    "gittyup.example.yaml",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run tests/unit/",
    "test:integration": "vitest run tests/integration/",
    "test:e2e": "vitest run tests/e2e/",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "git",
    "multi-repo",
    "cherry-pick",
    "merge",
    "conflict-resolution",
    "cli"
  ],
  "engines": {
    "node": ">=22",
    "bun": ">=1.3"
  },
  "dependencies": {
    "@ecruz165/cli-kit": "workspace:*",
    "@ecruz165/tui-view-components": "workspace:*",
    "@inquirer/prompts": "^8.2.0",
    "bun": "^1.3.13",
    "chalk": "^5.6.2",
    "cli-table3": "^0.6.5",
    "commander": "^14.0.3",
    "js-yaml": "^4.1.1",
    "octokit": "^4.0.2",
    "ora": "^8.1.0",
    "simple-git": "^3.27.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.2.3",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "restricted"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ecruz165/agentx-toolbox.git",
    "directory": "apps/gittyup"
  },
  "license": "MIT"
}

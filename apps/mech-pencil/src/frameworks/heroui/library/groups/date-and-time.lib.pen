{
  "version": "2.11",
  "imports": {
    "brand": "../brand.lib.pen"
  },
  "children": [
    {
      "id": "group-date-and-time",
      "type": "frame",
      "name": "Date and Time",
      "x": 0,
      "y": 0,
      "layout": "vertical",
      "gap": 40,
      "padding": 40,
      "fill": "$brand:color.background",
      "children": [
        {
          "id": "group-date-and-time-title",
          "type": "text",
          "content": "Date and Time · HeroUI v3",
          "fill": "$brand:color.foreground",
          "fontFamily": "$brand:font.family",
          "fontSize": 24,
          "fontWeight": "700"
        },
        {
          "id": "g-date-and-time-molecule",
          "type": "frame",
          "name": "molecules",
          "layout": "vertical",
          "width": "fit_content",
          "gap": 16,
          "children": [
            {
              "id": "g-date-and-time-molecule-h",
              "type": "text",
              "content": "MOLECULES",
              "fill": "$brand:color.muted",
              "fontFamily": "$brand:font.family",
              "fontSize": 13,
              "fontWeight": "600"
            },
            {
              "id": "g-date-and-time-molecule-items",
              "type": "frame",
              "name": "Items",
              "layout": "vertical",
              "width": "fit_content",
              "gap": 16,
              "children": [
                {
                  "id": "date-field",
                  "type": "frame",
                  "name": "DateField",
                  "width": 220,
                  "height": 40,
                  "layout": "horizontal",
                  "alignItems": "center",
                  "justifyContent": "space_between",
                  "padding": [
                    12,
                    0
                  ],
                  "cornerRadius": "$brand:radius.md",
                  "fill": "$brand:color.field-background",
                  "stroke": {
                    "thickness": "$brand:border.width",
                    "fill": "$brand:color.border"
                  },
                  "children": [
                    {
                      "id": "date-field-val",
                      "type": "text",
                      "content": "MM / DD / YYYY",
                      "fill": "$brand:color.field-placeholder",
                      "fontFamily": "$brand:font.family",
                      "fontSize": "$brand:font.size-md"
                    },
                    {
                      "id": "date-field-icon",
                      "type": "text",
                      "content": "▦",
                      "fill": "$brand:color.muted",
                      "fontFamily": "$brand:font.family",
                      "fontSize": "$brand:font.size-md"
                    }
                  ],
                  "reusable": true,
                  "metadata": {
                    "type": "component",
                    "framework": "heroui",
                    "atomic": "molecule",
                    "fidelity": "full",
                    "react": "DateField",
                    "package": "@heroui/react",
                    "slug": "date-field",
                    "category": "Date and Time",
                    "source": [
                      "brand.lib.pen",
                      "groups/date-and-time.lib.pen"
                    ]
                  }
                },
                {
                  "id": "time-field",
                  "type": "frame",
                  "name": "TimeField",
                  "width": 220,
                  "height": 40,
                  "layout": "horizontal",
                  "alignItems": "center",
                  "justifyContent": "space_between",
                  "padding": [
                    12,
                    0
                  ],
                  "cornerRadius": "$brand:radius.md",
                  "fill": "$brand:color.field-background",
                  "stroke": {
                    "thickness": "$brand:border.width",
                    "fill": "$brand:color.border"
                  },
                  "children": [
                    {
                      "id": "time-field-val",
                      "type": "text",
                      "content": "HH : MM",
                      "fill": "$brand:color.field-placeholder",
                      "fontFamily": "$brand:font.family",
                      "fontSize": "$brand:font.size-md"
                    },
                    {
                      "id": "time-field-icon",
                      "type": "text",
                      "content": "◷",
                      "fill": "$brand:color.muted",
                      "fontFamily": "$brand:font.family",
                      "fontSize": "$brand:font.size-md"
                    }
                  ],
                  "reusable": true,
                  "metadata": {
                    "type": "component",
                    "framework": "heroui",
                    "atomic": "molecule",
                    "fidelity": "full",
                    "react": "TimeField",
                    "package": "@heroui/react",
                    "slug": "time-field",
                    "category": "Date and Time",
                    "source": [
                      "brand.lib.pen",
                      "groups/date-and-time.lib.pen"
                    ]
                  }
                }
              ]
            }
          ]
        },

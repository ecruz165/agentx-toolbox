{
  "version": "2.11",
  "imports": {
    "brand": "../brand.lib.pen"
  },
  "children": [
    {
      "id": "group-layout",
      "type": "frame",
      "name": "Layout",
      "x": 0,
      "y": 0,
      "layout": "vertical",
      "gap": 40,
      "padding": 40,
      "fill": "$brand:color.background",
      "children": [
        {
          "id": "group-layout-title",
          "type": "text",
          "content": "Layout · HeroUI v3",
          "fill": "$brand:color.foreground",
          "fontFamily": "$brand:font.family",
          "fontSize": 24,
          "fontWeight": "700"
        },
        {
          "id": "g-layout-atom",
          "type": "frame",
          "name": "atoms",
          "layout": "vertical",
          "width": "fit_content",
          "gap": 16,
          "children": [
            {
              "id": "g-layout-atom-h",
              "type": "text",
              "content": "ATOMS",
              "fill": "$brand:color.muted",
              "fontFamily": "$brand:font.family",
              "fontSize": 13,
              "fontWeight": "600"
            },
            {
              "id": "g-layout-atom-items",
              "type": "frame",
              "name": "Items",
              "layout": "vertical",
              "width": "fit_content",
              "gap": 16,
              "children": [
                {
                  "id": "separator",
                  "type": "frame",
                  "name": "Separator",
                  "width": 240,
                  "height": 1,
                  "fill": "$brand:color.border",
                  "reusable": true,
                  "metadata": {
                    "type": "component",
                    "framework": "heroui",
                    "atomic": "atom",
                    "fidelity": "full",
                    "react": "Separator",
                    "package": "@heroui/react",
                    "slug": "separator",
                    "category": "Layout",
                    "source": [
                      "brand.lib.pen",
                      "groups/layout.lib.pen"
                    ]
                  }
                },
                {
                  "id": "surface",
                  "type": "frame",
                  "name": "Surface",
                  "width": 240,
                  "height": 120,
                  "layout": "horizontal",
                  "alignItems": "center",
                  "justifyContent": "center",
                  "fill": "$brand:color.surface",
                  "cornerRadius": "$brand:radius.lg",
                  "stroke": {
                    "thickness": "$brand:border.width",
                    "fill": "$brand:color.border"
                  },
                  "effect": {
                    "type": "shadow",
                    "shadowType": "outer",
                    "offset": {
                      "x": 0,
                      "y": 2
                    },
                    "blur": 10,
                    "spread": 0,
                    "color": "#0000001f"
                  },
                  "children": [
                    {
                      "id": "surface-label",
                      "type": "text",
                      "content": "Surface",
                      "fill": "$brand:color.muted",
                      "fontFamily": "$brand:font.family",
                      "fontSize": "$brand:font.size-sm"
                    }
                  ],
                  "reusable": true,
                  "metadata": {
                    "type": "component",
                    "framework": "heroui",
                    "atomic": "atom",
                    "fidelity": "full",
                    "react": "Surface",
                    "package": "@heroui/react",
                    "slug": "surface",
                    "category": "Layout",
                    "source": [
                      "brand.lib.pen",
                      "groups/layout.lib.pen"
                    ]
                  }
                }
              ]
            }
          ]
        },
        {
          "id": "g-layout-molecule",
          "type": "frame",
          "name": "molecules",
          "layout": "vertical",
          "width": "fit_content",
          "gap": 16,
          "children": [
            {
              "id": "g-layout-molecule-h",
              "type": "text",
              "content": "MOLECULES",
              "fill": "$brand:color.muted",
              "fontFamily": "$brand:font.family",
              "fontSize": 13,
              "fontWeight": "600"
            },
            {
              "id": "g-layout-molecule-items",
              "type": "frame",
              "name": "Items",
              "layout": "vertical",
              "width": "fit_content",
              "gap": 16,
              "children": [
                {
                  "id": "card",
                  "type": "frame",
                  "name": "Card",
                  "width": 360,
                  "fill": "$brand:color.surface",
                  "cornerRadius": "$brand:radius.lg",
                  "stroke": {
                    "thickness": "$brand:border.width",
                    "fill": "$brand:color.border"
                  },
                  "effect": {
                    "type": "shadow",
                    "shadowType": "outer",
                    "offset": {
                      "x": 0,
                      "y": 2
                    },
                    "blur": 8,
                    "spread": 0,
                    "color": "#0000001f"
                  },
                  "layout": "vertical",
                  "gap": 16,
                  "clip": true,
                  "children": [
                    {
                      "id": "card-header",
                      "type": "frame",
                      "name": "Header",
                      "layout": "vertical",
                      "gap": "$brand:space.unit",
                      "width": "fill_container",
                      "padding": [
                        20,
                        20,
                        0,
                        20
                      ],
                      "children": [
                        {
                          "id": "card-title",
                          "type": "text",
                          "content": "Card title",
                          "fill": "$brand:color.surface-foreground",
                          "fontFamily": "$brand:font.family",
                          "fontSize": "$brand:font.size-lg",
                          "fontWeight": "600"
                        },
                        {
                          "id": "card-subtitle",
                          "type": "text",
                          "content": "Supporting copy goes here.",
                          "fill": "$brand:color.muted",
                          "fontFamily": "$brand:font.family",
                          "fontSize": "$brand:font.size-sm"
                        }
                      ]
                    },
                    {
                      "id": "card-body",
                      "type": "frame",
                      "name": "Body",
                      "width": "fill_container",
                      "padding": 20,
                      "layout": "vertical",
                      "gap": "$brand:space.unit",
                      "children": [
                        {
                          "id": "card-body-text",
                          "type": "text",
                          "content": "Body content.",
                          "fill": "$brand:color.muted",
                          "fontFamily": "$brand:font.family",
                          "fontSize": "$brand:font.size-sm"
                        }
                      ]
                    },
                    {
                      "id": "card-footer",
                      "type": "frame",
                      "name": "Footer",
                      "width": "fill_container",
                      "padding": [
                        0,
                        20,
                        20,
                        20
                      ],
                      "layout": "horizontal",
                      "justifyContent": "end",
                      "gap": "$brand:space.unit"
                    }
                  ],
                  "reusable": true,
                  "metadata": {
                    "type": "component",
                    "framework": "heroui",
                    "atomic": "molecule",
                    "fidelity": "full",
                    "react": "Card",
                    "package": "@heroui/react",
                    "slug": "card",
                    "category": "Layout",
                    "source": [
                      "brand.lib.pen",
                      "groups/layout.lib.pen"
                    ]
                  }
                }
              ]
            }
          ]
        },
        {
          "id": "g-layout-organism",
          "type": "frame",
          "name": "organisms",
          "layout": "vertical",
          "width": "fit_content",
          "gap": 16,
          "children": [
            {
              "id": "g-layout-organism-h",
              "type": "text",
              "content": "ORGANISMS",
              "fill": "$brand:color.muted",
              "fontFamily": "$brand:font.family",
              "fontSize": 13,
              "fontWeight": "600"
            },
            {
              "id": "g-layout-organism-items",
              "type": "frame",
              "name": "Items",
              "layout": "vertical",
              "width": "fit_content",
              "gap": 16,
              "children": [
                {
                  "id": "toolbar",
                  "type": "frame",
                  "name": "Toolbar",
                  "layout": "horizontal",
                  "width": "fit_content",
                  "alignItems": "center",
                  "gap": 4,
                  "padding": 6,
                  "fill": "$brand:color.surface",
                  "cornerRadius": "$brand:radius.md",
                  "stroke": {
                    "thickness": "$brand:border.width",
                    "fill": "$brand:color.border"
                  },
                  "children": [
                    {
                      "id": "toolbar-b",
                      "type": "frame",
                      "width": 32,
                      "height": 32,
                      "layout": "horizontal",
                      "alignItems": "center",
                      "justifyContent": "center",
                      "cornerRadius": "$brand:radius.sm",
                      "fill": "transparent",
                      "children": [
                        {
                          "id": "toolbar-b-g",
                          "type": "text",
                          "content": "B",
                          "fill": "$brand:color.foreground",
                          "fontFamily": "$brand:font.family",
                          "fontSize": "$brand:font.size-md"
                        }
                      ]
                    },
                    {
                      "id": "toolbar-i",
                      "type": "frame",
                      "width": 32,
                      "height": 32,
                      "layout": "horizontal",
                      "alignItems": "center",
                      "justifyContent": "center",
                      "cornerRadius": "$brand:radius.sm",
                      "fill": "transparent",
                      "children": [
                        {
                          "id": "toolbar-i-g",
                          "type": "text",
                          "content": "I",
                          "fill": "$brand:color.foreground",
                          "fontFamily": "$brand:font.family",
                          "fontSize": "$brand:font.size-md"
                        }
                      ]
                    },
                    {
                      "id": "toolbar-u",
                      "type": "frame",
                      "width": 32,
                      "height": 32,
                      "layout": "horizontal",
                      "alignItems": "center",
                      "justifyContent": "center",
                      "cornerRadius": "$brand:radius.sm",
                      "fill": "transparent",
                      "children": [
                        {
                          "id": "toolbar-u-g",
                          "type": "text",
                          "content": "U",
                          "fill": "$brand:color.foreground",
                          "fontFamily": "$brand:font.family",
                          "fontSize": "$brand:font.size-md"
                        }
                      ]
                    },
                    {
                      "id": "toolbar-sep",
                      "type": "frame",
                      "width": 1,
                      "height": 24,
                      "fill": "$brand:color.border"
                    },
                    {
                      "id": "toolbar-l",
                      "type": "frame",
                      "width": 32,
                      "height": 32,
                      "layout": "horizontal",
                      "alignItems": "center",
                      "justifyContent": "center",
                      "cornerRadius": "$brand:radius.sm",
                      "fill": "transparent",
                      "children": [
                        {
                          "id": "toolbar-l-g",
                          "type": "text",
                          "content": "≣",
                          "fill": "$brand:color.foreground",
                          "fontFamily": "$brand:font.family",
                          "fontSize": "$brand:font.size-md"
                        }
                      ]
                    },
                    {
                      "id": "toolbar-c",
                      "type": "frame",
                      "width": 32,
                      "height": 32,
                      "layout": "horizontal",
                      "alignItems": "center",
                      "justifyContent": "center",
                      "cornerRadius": "$brand:radius.sm",
                      "fill": "transparent",
                      "children": [
                        {
                          "id": "toolbar-c-g",
                          "type": "text",
                          "content": "≡",
                          "fill": "$brand:color.foreground",
                          "fontFamily": "$brand:font.family",
                          "fontSize": "$brand:font.size-md"
                        }
                      ]
                    }
                  ],
                  "reusable": true,
                  "metadata": {
                    "type": "component",
                    "framework": "heroui",
                    "atomic": "organism",
                    "fidelity": "full",
                    "react": "Toolbar",
                    "package": "@heroui/react",
                    "slug": "toolbar",
                    "category": "Layout",
                    "source": [
                      "brand.lib.pen",
                      "groups/layout.lib.pen"
                    ]
                  }
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}

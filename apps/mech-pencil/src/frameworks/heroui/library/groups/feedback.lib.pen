                      "children": [
                        {
                          "id": "progress-bar-label",
                          "type": "text",
                          "content": "Uploading",
                          "fill": "$tokens:color.foreground",
                          "fontFamily": "$tokens:font.family",
                          "fontSize": "$tokens:font.size-sm",
                          "fontWeight": "600"
                        },
                        {
                          "id": "progress-bar-pct",
                          "type": "text",
                          "content": "60%",
                          "fill": "$tokens:color.muted",
                          "fontFamily": "$tokens:font.family",
                          "fontSize": "$tokens:font.size-sm"
                        }
                      ]
                    },
                    {
                      "id": "progress-bar-track",
                      "type": "frame",
                      "name": "Track",
                      "width": 240,
                      "height": 8,
                      "cornerRadius": 9999,
                      "fill": "$tokens:color.border",
                      "layout": "none",
                      "children": [
                        {
                          "id": "progress-bar-track-fill",
                          "type": "frame",
                          "x": 0,
                          "y": 0,
                          "width": 144,
                          "height": 8,
                          "cornerRadius": 9999,
                          "fill": "$tokens:color.accent"
                        }
                      ]
                    }
                  ],
                  "reusable": true,
                  "metadata": {
                    "type": "component",
                    "framework": "heroui",
                    "atomic": "atom",
                    "fidelity": "full",
                    "react": "ProgressBar",
                    "package": "@heroui/react",
                    "slug": "progress-bar",
                    "category": "Feedback",
                    "source": [
                      "design-tokens.lib.pen",
                      "groups/feedback.lib.pen"
                    ]
                  }
                },
                {
                  "id": "progress-circle",
                  "type": "frame",
                  "name": "ProgressCircle",
                  "width": 64,
                  "height": 64,
                  "layout": "none",
                  "children": [
                    {
                      "id": "progress-circle-track",
                      "type": "ellipse",
                      "width": 64,
                      "height": 64,
                      "fill": "$tokens:color.border",
                      "innerRadius": 0.8,
                      "startAngle": 0,
                      "sweepAngle": 360
                    },
                    {
                      "id": "progress-circle-arc",
                      "type": "ellipse",
                      "width": 64,
                      "height": 64,
                      "fill": "$tokens:color.accent",
                      "innerRadius": 0.8,
                      "startAngle": 90,
                      "sweepAngle": 252
                    },
                    {
                      "id": "progress-circle-text",
                      "type": "text",
                      "content": "70%",
                      "x": 18,
                      "y": 24,
                      "fill": "$tokens:color.foreground",
                      "fontFamily": "$tokens:font.family",
                      "fontSize": "$tokens:font.size-sm",
                      "fontWeight": "600"
                    }
                  ],
                  "reusable": true,
                  "metadata": {
                    "type": "component",
                    "framework": "heroui",
                    "atomic": "atom",
                    "fidelity": "full",
                    "react": "ProgressCircle",
                    "package": "@heroui/react",
                    "slug": "progress-circle",
                    "category": "Feedback",
                    "source": [
                      "design-tokens.lib.pen",
                      "groups/feedback.lib.pen"
                    ]
                  }
                }
              ]
            }
          ]
        },
        {
          "id": "g-feedback-molecule",
          "type": "frame",
          "name": "molecules",
          "layout": "vertical",
          "width": "fit_content",
          "gap": 16,
          "children": [
            {
              "id": "g-feedback-molecule-h",
              "type": "text",
              "content": "MOLECULES",
              "fill": "$tokens:color.muted",
              "fontFamily": "$tokens:font.family",
              "fontSize": 13,
              "fontWeight": "600"
            },
            {
              "id": "g-feedback-molecule-items",
              "type": "frame",
              "name": "Items",
              "layout": "vertical",
              "width": "fit_content",
              "gap": 16,
              "children": [
                {
                  "id": "alert",
                  "type": "frame",
                  "name": "Alert",
                  "width": 380,
                  "layout": "horizontal",
                  "alignItems": "start",
                  "gap": 12,
                  "padding": 16,
                  "fill": "$tokens:color.accent-soft",
                  "cornerRadius": "$tokens:radius.md",
                  "children": [
                    {
                      "id": "alert-dot",
                      "type": "frame",
                      "name": "Dot",
                      "width": 10,
                      "height": 10,
                      "fill": "$tokens:color.accent",
                      "cornerRadius": 9999
                    },
                    {
                      "id": "alert-content",
                      "type": "frame",
                      "name": "Content",
                      "layout": "vertical",
                      "width": "fill_container",
                      "gap": 4,
                      "children": [
                        {
                          "id": "alert-title",
                          "type": "text",
                          "content": "Heads up",
                          "fill": "$tokens:color.foreground",
                          "fontFamily": "$tokens:font.family",
                          "fontSize": "$tokens:font.size-md",
                          "fontWeight": "600"
                        },
                        {
                          "id": "alert-body",
                          "type": "text",
                          "content": "Something needs your attention.",
                          "fill": "$tokens:color.muted",
                          "fontFamily": "$tokens:font.family",
                          "fontSize": "$tokens:font.size-sm",
                          "textGrowth": "fixed-width",
                          "width": "fill_container"
                        }
                      ]
                    }
                  ],
                  "reusable": true,
                  "metadata": {
                    "type": "component",
                    "framework": "heroui",
                    "atomic": "molecule",
                    "fidelity": "full",
                    "react": "Alert",
                    "package": "@heroui/react",
                    "slug": "alert",
                    "category": "Feedback",
                    "source": [
                      "design-tokens.lib.pen",
                      "groups/feedback.lib.pen"
                    ]
                  }
                }
              ]
            }
          ]

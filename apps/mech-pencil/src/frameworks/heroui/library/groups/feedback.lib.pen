{
  "version": "2.11",
  "imports": {
    "tokens": "../design-tokens.lib.pen"
  },
  "children": [
    {
      "id": "group-feedback",
      "type": "frame",
      "name": "Feedback",
      "x": 0,
      "y": 0,
      "layout": "vertical",
      "gap": 40,
      "padding": 40,
      "fill": "$tokens:color.background",
      "children": [
        {
          "id": "group-feedback-title",
          "type": "text",
          "content": "Feedback · HeroUI v3",
          "fill": "$tokens:color.foreground",
          "fontFamily": "$tokens:font.family",
          "fontSize": 24,
          "fontWeight": "700"
        },
        {
          "id": "g-feedback-atom",
          "type": "frame",
          "name": "atoms",
          "layout": "vertical",
          "width": "fit_content",
          "gap": 16,
          "children": [
            {
              "id": "g-feedback-atom-h",
              "type": "text",
              "content": "ATOMS",
              "fill": "$tokens:color.muted",
              "fontFamily": "$tokens:font.family",
              "fontSize": 13,
              "fontWeight": "600"
            },
            {
              "id": "g-feedback-atom-items",
              "type": "frame",
              "name": "Items",
              "layout": "vertical",
              "width": "fit_content",
              "gap": 16,
              "children": [
                {
                  "id": "spinner",
                  "type": "frame",
                  "name": "Spinner",
                  "width": 32,
                  "height": 32,
                  "layout": "none",
                  "children": [
                    {
                      "id": "spinner-track",
                      "type": "ellipse",
                      "width": 32,
                      "height": 32,
                      "fill": "$tokens:color.border",
                      "innerRadius": 0.8,
                      "startAngle": 0,
                      "sweepAngle": 360
                    },
                    {
                      "id": "spinner-arc",
                      "type": "ellipse",
                      "width": 32,
                      "height": 32,
                      "fill": "$tokens:color.accent",
                      "innerRadius": 0.8,
                      "startAngle": 90,
                      "sweepAngle": 280
                    }
                  ],
                  "reusable": true,
                  "metadata": {
                    "type": "component",
                    "framework": "heroui",
                    "atomic": "atom",
                    "fidelity": "full",
                    "react": "Spinner",
                    "package": "@heroui/react",
                    "slug": "spinner",
                    "category": "Feedback",
                    "source": [
                      "design-tokens.lib.pen",
                      "groups/feedback.lib.pen"
                    ]
                  }
                },
                {
                  "id": "skeleton",
                  "type": "frame",
                  "name": "Skeleton",
                  "width": 240,
                  "layout": "vertical",
                  "gap": 10,
                  "children": [
                    {
                      "id": "skeleton-a",
                      "type": "frame",
                      "width": 240,
                      "height": 16,
                      "cornerRadius": "$tokens:radius.sm",
                      "fill": "$tokens:color.border"
                    },
                    {
                      "id": "skeleton-b",
                      "type": "frame",
                      "width": 180,
                      "height": 16,
                      "cornerRadius": "$tokens:radius.sm",
                      "fill": "$tokens:color.border"
                    },
                    {
                      "id": "skeleton-c",
                      "type": "frame",
                      "width": 210,
                      "height": 16,
                      "cornerRadius": "$tokens:radius.sm",
                      "fill": "$tokens:color.border"
                    }
                  ],
                  "reusable": true,
                  "metadata": {
                    "type": "component",
                    "framework": "heroui",
                    "atomic": "atom",
                    "fidelity": "full",
                    "react": "Skeleton",
                    "package": "@heroui/react",
                    "slug": "skeleton",
                    "category": "Feedback",
                    "source": [
                      "design-tokens.lib.pen",
                      "groups/feedback.lib.pen"
                    ]
                  }
                },
                {
                  "id": "meter",
                  "type": "frame",
                  "name": "Meter",
                  "width": 240,
                  "layout": "vertical",
                  "gap": 6,
                  "children": [
                    {
                      "id": "meter-track",
                      "type": "frame",
                      "name": "Track",
                      "width": 240,
                      "height": 8,
                      "cornerRadius": 9999,
                      "fill": "$tokens:color.border",
                      "layout": "none",
                      "children": [

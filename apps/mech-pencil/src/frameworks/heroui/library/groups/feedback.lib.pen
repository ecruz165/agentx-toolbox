                          "id": "meter-track-fill",
                          "type": "frame",
                          "x": 0,
                          "y": 0,
                          "width": 168,
                          "height": 8,
                          "cornerRadius": 9999,
                          "fill": "$tokens:color.accent"
                        }
                      ]
                    }
                  ],
                  "reusable": true,
                  "metadata": {
                    "type": "component",
                    "framework": "heroui",
                    "atomic": "atom",
                    "fidelity": "full",
                    "react": "Meter",
                    "package": "@heroui/react",
                    "slug": "meter",
                    "category": "Feedback",
                    "source": [
                      "design-tokens.lib.pen",
                      "groups/feedback.lib.pen"
                    ]
                  }
                },
                {
                  "id": "progress-bar",
                  "type": "frame",
                  "name": "ProgressBar",
                  "width": 240,
                  "layout": "vertical",
                  "gap": 6,
                  "children": [
                    {
                      "id": "progress-bar-row",
                      "type": "frame",
                      "layout": "horizontal",
                      "width": "fill_container",

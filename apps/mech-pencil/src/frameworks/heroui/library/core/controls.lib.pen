{
  "version": "2.11",
  "imports": {
    "tokens": "../design-tokens.lib.pen"
  },
  "children": [
    {
      "id": "group-controls",
      "type": "frame",
      "name": "Controls",
      "x": 0,
      "y": 0,
      "layout": "vertical",
      "gap": 40,
      "padding": 40,
      "fill": "$tokens:color.background",
      "children": [
        {
          "id": "group-controls-title",
          "type": "text",
          "content": "Controls · HeroUI v3",
          "fill": "$tokens:color.foreground",
          "fontFamily": "$tokens:font.family",
          "fontSize": 24,
          "fontWeight": "700"
        },
        {
          "id": "g-controls-atom",
          "type": "frame",
          "name": "atoms",
          "layout": "vertical",
          "width": "fit_content",
          "gap": 16,
          "children": [
            {
              "id": "g-controls-atom-h",
              "type": "text",
              "content": "ATOMS",
              "fill": "$tokens:color.muted",
              "fontFamily": "$tokens:font.family",
              "fontSize": 13,
              "fontWeight": "600"
            },
            {
              "id": "g-controls-atom-items",
              "type": "frame",
              "name": "Items",
              "layout": "vertical",
              "width": "fit_content",
              "gap": 16,
              "children": [
                {
                  "id": "switch",
                  "type": "frame",
                  "name": "Switch",
                  "width": 44,
                  "height": 24,
                  "layout": "horizontal",
                  "alignItems": "center",
                  "justifyContent": "end",
                  "padding": [
                    2,
                    2
                  ],
                  "fill": "$tokens:color.accent",
                  "cornerRadius": 9999,
                  "children": [
                    {
                      "id": "switch-knob",
                      "type": "frame",
                      "name": "Knob",
                      "width": 20,
                      "height": 20,
                      "fill": "$tokens:color.surface",
                      "cornerRadius": 9999
                    }
                  ],
                  "reusable": true,
                  "metadata": {
                    "type": "component",
                    "framework": "heroui",
                    "atomic": "atom",
                    "fidelity": "full",
                    "react": "Switch",
                    "package": "@heroui/react",
                    "slug": "switch",
                    "category": "Controls",
                    "source": [
                      "design-tokens.lib.pen",
                      "core/controls.lib.pen"
                    ]
                  }
                },
                {
                  "id": "slider",
                  "type": "frame",
                  "name": "Slider",
                  "width": 240,
                  "height": 20,
                  "layout": "none",
                  "children": [
                    {
                      "id": "slider-track",
                      "type": "frame",
                      "name": "Track",
                      "x": 0,
                      "y": 7,
                      "width": 240,
                      "height": 6,
                      "cornerRadius": 9999,
                      "fill": "$tokens:color.border"
                    },
                    {
                      "id": "slider-fill",
                      "type": "frame",
                      "name": "Fill",
                      "x": 0,
                      "y": 7,
                      "width": 108,
                      "height": 6,
                      "cornerRadius": 9999,
                      "fill": "$tokens:color.accent"
                    },
                    {
                      "id": "slider-thumb",
                      "type": "frame",
                      "name": "Thumb",
                      "x": 100,
                      "y": 1,
                      "width": 18,
                      "height": 18,
                      "cornerRadius": 9999,
                      "fill": "$tokens:color.surface",
                      "stroke": {
                        "thickness": 2,
                        "fill": "$tokens:color.accent"
                      }
                    }
                  ],
                  "reusable": true,
                  "metadata": {
                    "type": "component",
                    "framework": "heroui",
                    "atomic": "atom",
                    "fidelity": "full",
                    "react": "Slider",
                    "package": "@heroui/react",
                    "slug": "slider",
                    "category": "Controls",
                    "source": [
                      "design-tokens.lib.pen",
                      "core/controls.lib.pen"
                    ]
                  }
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}

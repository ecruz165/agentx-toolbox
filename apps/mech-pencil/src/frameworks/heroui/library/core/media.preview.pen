{
  "version": "2.11",
  "imports": {
    "tokens": "../design-tokens.lib.pen"
  },
  "children": [
    {
      "id": "group-media",
      "type": "frame",
      "name": "Media",
      "x": 0,
      "y": 0,
      "layout": "vertical",
      "gap": 40,
      "padding": 40,
      "fill": "$tokens:color.background",
      "children": [
        {
          "id": "group-media-title",
          "type": "text",
          "content": "Media · HeroUI v3",
          "fill": "$tokens:color.foreground",
          "fontFamily": "$tokens:font.family",
          "fontSize": 24,
          "fontWeight": "700"
        },
        {
          "id": "g-media-atom",
          "type": "frame",
          "name": "atoms",
          "layout": "vertical",
          "width": "fit_content",
          "gap": 16,
          "children": [
            {
              "id": "g-media-atom-h",
              "type": "text",
              "content": "ATOMS",
              "fill": "$tokens:color.muted",
              "fontFamily": "$tokens:font.family",
              "fontSize": 13,
              "fontWeight": "600"
            },
            {
              "id": "g-media-atom-items",
              "type": "frame",
              "name": "Items",
              "layout": "vertical",
              "width": "fit_content",
              "gap": 16,
              "children": [
                {
                  "id": "avatar",
                  "type": "frame",
                  "name": "Avatar",
                  "width": 40,
                  "height": 40,
                  "layout": "horizontal",
                  "alignItems": "center",
                  "justifyContent": "center",
                  "fill": "$tokens:color.accent",
                  "cornerRadius": 9999,
                  "children": [
                    {
                      "id": "avatar-initials",
                      "type": "text",
                      "content": "AB",
                      "fill": "$tokens:color.accent-foreground",
                      "fontFamily": "$tokens:font.family",
                      "fontSize": 14,
                      "fontWeight": "600"
                    }
                  ],
                  "reusable": true,
                  "metadata": {
                    "type": "component",
                    "framework": "heroui",
                    "atomic": "atom",
                    "fidelity": "full",
                    "react": "Avatar",
                    "package": "@heroui/react",
                    "slug": "avatar",
                    "category": "Media",
                    "source": [
                      "design-tokens.lib.pen",
                      "core/media.lib.pen"
                    ]
                  }
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}

{
  "name": "@ecruz165/mech-pencil",
  "version": "0.0.1",
  "description": "mech-pencil — generates Pencil .pen design systems and base mockups from framework adapters (HeroUI v3). Part of the agentx-toolbox monorepo.",
  "type": "module",
  "bin": {
    "mech-pencil": "./bin/mech-pencil.mjs"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./cli": {
      "import": "./dist/cli.js"
    }
  },
  "files": [
    "dist",
    "bin",
    "src/frameworks/heroui/library",
    "skill",
    "README.md"
  ],
  "scripts": {
    "build": "tsup && bun build ./src/cli.ts --outdir ./dist --target bun --format esm --packages external",
    "dev": "bun run src/cli.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "vitest run tests/e2e",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "cli",
    "pencil",
    "design-system",
    "heroui",
    "atomic-design"
  ],
  "dependencies": {
    "@ecruz165/cli-kit": "workspace:*",
    "@ecruz165/tui-view-components": "workspace:*",
    "@opentui/core": "^0.2.2",
    "@opentui/react": "^0.2.2",
    "bun": "^1.3.13",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "react": "^19.2.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.5"
  },
  "engines": {
    "node": ">=22",
    "bun": ">=1.3"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "restricted"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ecruz165/agentx-toolbox.git",
    "directory": "apps/mech-pencil"
  },
  "license": "UNLICENSED"
}

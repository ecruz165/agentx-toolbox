{
  "name": "@ecruz165/gitradar",
  "version": "0.1.0",
  "description": "Terminal-based TUI analytics tool for git contribution data. Part of the agentx-toolbox monorepo.",
  "type": "module",
  "bin": {
    "gitradar": "dist/cli.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/cli.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "vitest run tests/e2e",
    "typecheck": "tsc --noEmit"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ecruz165/agentx-toolbox.git",
    "directory": "apps/gitradar"
  },
  "license": "UNLICENSED",
  "dependencies": {
    "@ecruz165/cli-kit": "workspace:*",
    "@ecruz165/tui-view-components": "workspace:*",
    "@inquirer/prompts": "^8.2.0",
    "better-sqlite3": "^12.6.2",
    "bun": "^1.3.13",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "js-yaml": "^4.1.1",
    "octokit": "^4.0.2",
    "ora": "^8.1.0",
    "p-limit": "^7.3.0",
    "simple-git": "^3.27.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.2.3",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}

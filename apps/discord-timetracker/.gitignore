# Local runtime artifacts (root .gitignore already covers dist/, node_modules/)
# Secrets must never be committed (.env, .env.bak, .env.local, …)
.env
.env.*
# …but keep the checked-in template
!.env.example
# Generated by `setup` — per-environment runtime config (real guild/channel IDs)
timetracker.config.json
data/
*.db
*.db-shm
*.db-wal

{
  "name": "@ecruz165/discord-timetracker",
  "version": "0.1.0",
  "description": "Admin-only Discord bot that tracks per-user daily activity (start/end of day, presence, CI submissions, channel engagement) with a TUI for daily/weekly summaries. Part of the agentx-toolbox monorepo.",
  "type": "module",
  "bin": {
    "discord-timetracker": "./bin/discord-timetracker.mjs"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "bin",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/cli.ts",
    "start": "tsx src/cli.ts start",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit --allowImportingTsExtensions"
  },
  "dependencies": {
    "@ecruz165/cli-kit": "workspace:*",
    "@ecruz165/tui-view-components": "workspace:*",
    "@inquirer/prompts": "^8.2.0",
    "@opentui/core": "^0.2.2",
    "@opentui/react": "^0.2.2",
    "commander": "^14.0.3",
    "discord.js": "^14.16.3",
    "react": "^19.2.0",
    "zod": "^3.25.32"
  },
  "optionalDependencies": {
    "@aws-sdk/client-dynamodb": "^3.700.0",
    "@aws-sdk/lib-dynamodb": "^3.700.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.0",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.5"
  },
  "engines": {
    "node": ">=22",
    "bun": ">=1.3"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "restricted"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ecruz165/agentx-toolbox.git",
    "directory": "apps/discord-timetracker"
  },
  "license": "UNLICENSED"
}

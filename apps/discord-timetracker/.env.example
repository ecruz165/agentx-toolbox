# ─── Discord ──────────────────────────────────────────────────────────
DISCORD_TOKEN=               # bot token from the Developer Portal
GUILD_ID=                    # the server (guild) ID to track

# Text channel IDs (right-click channel → Copy ID; enable Developer Mode)
GOALS_CHANNEL_ID=            # #goals-for-the-day   → start of day
SUMMARY_CHANNEL_ID=          # #summary-of-the-day  → end of day
CI_CHANNEL_ID=               # #ci-cd-notifications → CI submissions (GitHub Monitor)

# Voice channels that count toward engagement (comma-separated). Drives BOTH
# voice-connection time AND text messages in each channel's embedded chat.
VOICE_CHANNEL_IDS=           # e.g. DevOffice,TriageRoom,ProjectOffice,DesignStudio

# Admin gating / reporting
ADMIN_ROLE_ID=               # role allowed to run commands / see reports
REPORT_CHANNEL_ID=           # admin-only channel for pushed summaries
TRACKED_ROLE_ID=             # optional: only track members with this role

# ─── Behaviour ────────────────────────────────────────────────────────
TIMEZONE=America/New_York    # day-boundary timezone for daily/weekly buckets
SCHEDULE_DAILY_AT=09:00      # local HH:MM to push summaries to the report channel

# ─── Storage ──────────────────────────────────────────────────────────
STORAGE_BACKEND=sqlite       # sqlite | dynamodb
SQLITE_PATH=./data/timetracker.db

# Only when STORAGE_BACKEND=dynamodb:
# AWS_REGION=us-east-1
# DDB_TABLE=timetracker

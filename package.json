{
  "name": "@ecruz165/skillzkit",
  "version": "0.1.0",
  "description": "AgentX skillz suite — commands, skills, and workflows for Claude Code and the AgentX platform.",
  "type": "module",
  "bin": {
    "skillzkit": "./dist/bin/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/lib/index.d.ts",
      "import": "./dist/lib/index.js"
    }
  },
  "files": [
    "dist",
    "catalog.json",
    ".claude/commands",
    ".claude/skills",
    "README.md"
  ],
  "scripts": {
    "catalog": "tsx scripts/generate-catalog.ts",
    "build": "npm run catalog && tsc",
    "prepublishOnly": "npm run build",
    "cli": "tsx bin/cli.ts"
  },
  "dependencies": {
    "@opentui/core": "^0.2.2",
    "@opentui/react": "^0.2.2",
    "bun": "^1.3.13",
    "cac": "^6.7.14",
    "gray-matter": "^4.0.3",
    "react": "^19.2.0",
    "react-reconciler": "^0.32.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "restricted"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ecruz165/agentx-skillzkit.git"
  },
  "license": "UNLICENSED"
}

{
  "name": "@agentx/agent-adapter",
  "version": "0.0.1",
  "description": "Multi-agent LLM provider adapters for AgentX. Anthropic / OpenAI / Copilot / LangGraph / opencode adapters behind a uniform interface, plus capture / replay helpers.",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@agentx/agent-auth": "*",
    "@anthropic-ai/sdk": "^0.30.1",
    "@langchain/core": "^1.1.44",
    "@langchain/langgraph": "^1.3.0",
    "zod": "^3.25.32"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.5"
  },
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "restricted"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ecruz165/agentx-toolbox.git",
    "directory": "packages/agent-adapter"
  },
  "license": "UNLICENSED"
}

{
  "name": "@agentx/agent-worker",
  "version": "0.0.1",
  "description": "Worker primitives for AgentX agent runs — sandbox + tmux + skill-prompt assembly. Built on @agentx/agent-adapter and @agentx/agent-auth.",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@agentx/agent-adapter": "*",
    "@agentx/agent-auth": "*"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.5"
  },
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "restricted"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ecruz165/agentx-toolbox.git",
    "directory": "packages/agent-worker"
  },
  "license": "UNLICENSED"
}
